{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "linter": {
    "includes": ["**"],
    "rules": {
      "style": {
        "useImportType": "off",
        "useBlockStatements": "warn",
        "noNestedTernary": "warn"
      },
      "a11y": {
        "useKeyWithClickEvents": "off"
      },
      "complexity": {
        "noForEach": "off"
      },
      "performance": {
        "noAccumulatingSpread": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "warn"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules/**/*",
      "!**/dist/**/*",
      "!**/.next/**/*",
      "!**/@generated/**/*"
    ]
  },
  "formatter": {
    "formatWithErrors": true,
    "indentStyle": "space",
    "includes": ["**"]
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    },
    "formatter": {
      "enabled": true,
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 80,
      "lineEnding": "lf"
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 80,
      "lineEnding": "lf"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
