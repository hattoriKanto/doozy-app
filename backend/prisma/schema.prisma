generator client {
  provider     = "prisma-client"
  moduleFormat = "cjs"
  output       = "../src/@generated/prisma-client"
}

datasource db {
  provider = "sqlite"
}

enum TodoStatus {
  completed
  notCompleted
}

model Todo {
  id String @id @default(uuid())

  title       String
  description String?
  status      TodoStatus @default(notCompleted)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id String @id @default(uuid())

  title String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
